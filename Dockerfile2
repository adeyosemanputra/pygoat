# Use a Python base image
FROM python:3.11-slim-bookworm

# Install necessary system dependencies without hardcoded EOL versions
# Allows the package manager to fetch the latest secure versions
RUN apt-get update && apt-get install --no-install-recommends -y \
  dnsutils \
  libpq-dev \
  python3-dev \
  gcc \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# Set work directory
WORKDIR /app

# Install dependencies (The SCA part of your lab)
COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

# Copy project
COPY . /app/

# Run migrations and start the app (The "Lean" approach)
RUN python manage.py migrate
EXPOSE 8000

CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
